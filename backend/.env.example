# Copier ce fichier en ".env" et renseigner vos propres valeurs.
# Ne jamais committer le fichier ".env" reel dans Git (voir .gitignore).

# ---------- MySQL / MariaDB ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fantasyrealm
DB_USER=root
DB_PASSWORD=

# ---------- MongoDB ----------
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=fantasyrealm_logs

# ---------- Front-end ----------
# Origine exacte (schema + hote + port) autorisee a appeler l'API en
# cross-origin avec les cookies de session (credentials: 'include').
FRONTEND_ORIGIN=http://localhost:5500
